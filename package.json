{
  "name": "smart-db",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev": "pnpm -r --parallel --filter @smart-db/middleware --filter @smart-db/frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.0.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
